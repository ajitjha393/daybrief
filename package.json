{
  "name": "daybrief",
  "version": "0.3.0",
  "description": "Your day, briefed. A read-only morning dashboard for teams on Azure DevOps + Jira + Bitbucket: PRs waiting on you, your PRs stuck on others, pipeline health and sprint state — one screen, no metrics theater.",
  "type": "module",
  "bin": {
    "daybrief": "bin/daybrief.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "npm run build:server && node bin/daybrief.js --mock --no-open",
    "dev:web": "vite --config web/vite.config.ts",
    "build": "npm run build:server && npm run build:web",
    "build:server": "tsc -p server",
    "build:web": "vite build --config web/vite.config.ts",
    "typecheck": "tsc -p server --noEmit && tsc -p web --noEmit",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "files": [
    "bin",
    "dist",
    "web/dist",
    "daybrief.example.json",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "azure-devops",
    "jira",
    "bitbucket",
    "dashboard",
    "pull-requests",
    "code-review",
    "pipelines",
    "standup",
    "team",
    "developer-tools"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^10.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^6.4.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
