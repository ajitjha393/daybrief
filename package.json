{
  "name": "daybrief",
  "version": "0.1.0",
  "description": "Your day, briefed. A read-only morning dashboard for teams on Azure DevOps + Jira + Bitbucket: PRs waiting on you, your PRs stuck on others, pipeline health and sprint state — one screen, no metrics theater.",
  "type": "module",
  "bin": {
    "daybrief": "bin/daybrief.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node bin/daybrief.js --mock --no-open",
    "dev:web": "vite --config web/vite.config.ts",
    "build": "vite build --config web/vite.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --test test/*.test.js"
  },
  "files": [
    "bin",
    "server",
    "web/dist",
    "daybrief.example.json",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "azure-devops",
    "jira",
    "bitbucket",
    "dashboard",
    "pull-requests",
    "code-review",
    "pipelines",
    "standup",
    "team",
    "developer-tools"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
